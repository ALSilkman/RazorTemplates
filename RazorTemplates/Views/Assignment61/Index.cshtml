@model RazorTemplates.Models.Assignment61View


<h2>Assignment 6.1</h2>

@if (Model.AccessLevel < 2)
{
    <p>You do not have a sufficient access level to view this data.</p>

}
else
{
    if(Model.AccessLevel >= 8)
    {
        <h4>Hello Admin</h4>
    }

    ViewData["AccessLevel"] = Model.AccessLevel;
    
    <ul>
        @foreach (var student in Model.Students)
        {
            <li>
               <partial 
                   name="_StudentNamePartial" model="student" />
            </li>


        }
    </ul>
}

